{
    "schema_version": 2,
    "description": "Hash of muon smearing correction",
    "corrections": [
        {
            "name": "RandomSmearing",
            "description": "Deterministic smearing value generator",
            "version": 1,
            "inputs": [
                {
                    "name": "evtNr",
                    "type": "int",
                    "description": "Event number (entropy source)"
                },
                {
                    "name": "lumiNr",
                    "type": "int",
                    "description": "Luminosity block number (entropy source)"
                },
                {
                    "name": "phi",
                    "type": "real",
                    "description": "Muon azimuthal angle"
                }
            ],
            "output": {
                "name": "rng",
                "type": "real"
            },
            "data": {
                "nodetype": "hashprng",
                "inputs": [
                    "evtNr",
                    "lumiNr",
                    "phi"
                ],
                "distribution": "stdflat"
            }
        }
    ]
}